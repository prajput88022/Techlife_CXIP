NODE_ENV=production
PORT=8000
APP_NAME=Tech-Life CXIP
APP_URL=http://localhost

JWT_SECRET=CHANGE_ME_openssl_rand_hex_64
JWT_EXPIRES_IN=7d
WEBHOOK_SECRET=CHANGE_ME_openssl_rand_hex_32

COUCHDB_URL=http://127.0.0.1:5984
COUCHDB_USER=admin
COUCHDB_PASSWORD=CHANGE_ME
COUCHDB_PREFIX=cxip_

REDIS_URL=redis://127.0.0.1:6379
REDIS_PASSWORD=CHANGE_ME

ADMIN_EMAIL=admin@yourcompany.com
ADMIN_PASSWORD=CHANGE_ME_min8chars
ADMIN_FULL_NAME=Administrator

# Industry: call_center | sales | insurance | banking | telecom | healthcare | real_estate | ecommerce
INDUSTRY=call_center

# STT: whisper | deepgram | azure | google | ibm | assemblyai
STT_PROVIDER=whisper
WHISPER_LANGUAGE=en
DEEPGRAM_API_KEY=
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastus
GOOGLE_STT_KEY=
IBM_STT_API_KEY=
IBM_STT_URL=https://api.us-east.speech-to-text.watson.cloud.ibm.com
IBM_STT_MODEL=en-US_BroadbandModel
ASSEMBLYAI_API_KEY=

# LLM: openai | claude | azure_openai | gemini | deepseek | ibm | mistral | ollama | virtuallab
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
AZURE_OPENAI_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-05-01-preview
GOOGLE_GEMINI_KEY=
GOOGLE_GEMINI_MODEL=gemini-2.5-pro
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com
IBM_WATSONX_API_KEY=
IBM_WATSONX_PROJECT_ID=
IBM_WATSONX_URL=https://us-south.ml.cloud.ibm.com
IBM_WATSONX_MODEL=ibm/granite-3-8b-instruct
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-large-latest
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b
VIRTUALLAB_API_KEY=
VIRTUALLAB_URL=

UPLOAD_DIR=/var/lib/cxip/audio
REPORTS_DIR=/var/lib/cxip/reports
MAX_UPLOAD_SIZE_MB=500
LOG_DIR=/var/log/cxip

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=CXIP <reports@yourcompany.com>

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
ZENDESK_API_KEY=
ZENDESK_SUBDOMAIN=
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
FRESHDESK_API_KEY=
SENTRY_DSN=
